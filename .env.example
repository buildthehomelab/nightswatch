# ── TrueNAS SCALE integration ────────────────────────────────────────────────
# These are server-side only (no VITE_ prefix) — injected at the proxy layer,
# never exposed to the browser.

TRUENAS_HOST=nas.local          # hostname or IP of your TrueNAS instance
TRUENAS_PORT=443                # HTTPS port (default 443)
TRUENAS_KEY=your-api-key-here   # TrueNAS API key (Settings → API Keys)

# Browser-facing URL for links back to the TrueNAS UI.
# Use this when you have split DNS (browser reaches NAS via a different URL
# than the Vite proxy does). Leave blank to derive from TRUENAS_HOST/PORT.
TRUENAS_UI_URL=https://nas.local

# Hide stopped apps from the ambient NAS strip after N minutes (default 60).
TRUENAS_STOPPED_APP_HIDE_MINUTES=60

# Pool usage thresholds (percent). Defaults: warn=80, crit=90.
TRUENAS_POOL_WARN_PCT=80
TRUENAS_POOL_CRIT_PCT=90

# Temperature thresholds (°C). CPU defaults: warn=70, crit=85.
# Disk defaults: warn=45, crit=55 (SSDs get +10°C automatically).
TRUENAS_DISK_WARN_C=45
TRUENAS_DISK_CRIT_C=55

# ── Sandbox panels ────────────────────────────────────────────────────────────
# URLs for the two configurable iframe panels (h = left, l = right).
# Leave blank to disable; users can also override these in the Customize panel.
SANDBOX_LEFT_URL=
SANDBOX_RIGHT_URL=

# ── Weather ───────────────────────────────────────────────────────────────────
# Location string passed to wttr.in. Leave blank to disable weather entirely.
# Examples: "London", "New York", "48.8566,2.3522"
WEATHER_LOCATION=

# ── CVE security feed ─────────────────────────────────────────────────────────
# Comma-separated keywords to search in the NIST NVD vulnerability database.
# "truenas" is auto-appended when TrueNAS integration is enabled.
# Examples: "plex,nginx,unifi,proxmox"
CVE_KEYWORDS=

# How many days back to search NVD (default 30).
CVE_DAYS_BACK=30

# Minimum CVSS score to surface as an issue (default 4.0).
# Set higher (e.g. 7.0) to see only high/critical CVEs.
CVE_MIN_CVSS=4.0

# ── Docker integration ────────────────────────────────────────────────────────
# Unix socket (same-host deployment, no socat required).
# Set this when the Vite dev server runs on the Docker host.
DOCKER_SOCKET=/var/run/docker.sock

# TCP remote host via socat bridge (alternative to DOCKER_SOCKET).
# Run on the Docker host: socat TCP-LISTEN:2375,fork,reuseaddr UNIX-CLIENT:/var/run/docker.sock
# DOCKER_SOCKET takes precedence when both are set.
DOCKER_HOST=docker.local
DOCKER_PORT=2375

# Optional: Portainer URL for action links in issue detail panels.
DOCKER_UI_URL=

# Restart count threshold for surfacing a high-restart warning (default 5).
DOCKER_RESTART_WARN=5

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to "true" to run with mock data (no real TrueNAS required).
# Cycles through healthy → advisory → warning → critical states automatically.
DEMO=false
